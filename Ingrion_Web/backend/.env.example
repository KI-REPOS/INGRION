# INGRION Backend — Environment Configuration
# Copy to .env and fill in values

# Django
DJANGO_SETTINGS_MODULE=ingrion_project.settings.production
DJANGO_SECRET_KEY=REPLACE-WITH-64-CHAR-RANDOM-SECRET
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Government Archive API
GOVERNMENT_ARCHIVE_API_URL=https://api.gov-archive.example.com/v1/verify
GOVERNMENT_API_KEY=your-gov-api-key-here
GOVERNMENT_CALLBACK_HMAC_SECRET=64-char-shared-hmac-secret-negotiated-with-government
GOVERNMENT_CALLBACK_URL=https://api.yourdomain.com/api/kyc/callback/

# Download
DOWNLOAD_TOKEN_EXPIRY_SECONDS=900
APPLICATION_BINARY_PATH=/srv/ingrion/protected/ingrion-app.bin
