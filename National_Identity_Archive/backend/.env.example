# Government Archive Platform — Environment Variables

DJANGO_SECRET_KEY=change-this-to-a-random-64-char-secret
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5174,https://your-frontend.com
CSRF_TRUSTED_ORIGINS=http://localhost:5174,https://your-frontend.com

# Facial similarity threshold (0.0 - 1.0, default 0.75)
FACIAL_SIMILARITY_THRESHOLD=0.75

# Archive link expiry in seconds (default 86400 = 24 hours)
ARCHIVE_LINK_EXPIRY_SECONDS=86400

# Shared HMAC secret with INGRION platform
# Must match GOVERNMENT_CALLBACK_HMAC_SECRET in INGRION's .env
INGRION_HMAC_SECRET=CHANGE-THIS-SHARED-SECRET-MUST-MATCH-INGRION
